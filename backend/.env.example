# Postgres (Railway injects DATABASE_URL when Postgres plugin attached)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# TLS: require for Railway public TCP proxy; disable for *.railway.internal
# PGSSL=require

# JWT signing — generate: openssl rand -base64 48
JWT_SECRET=replace-with-32-byte-random

# Resend API key (set in Railway dashboard only — never commit real value)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender in Resend
EMAIL_FROM=District 1 <info@retail-odyssey.com>

# Optional reply-to fallback when author email unavailable
# RESEND_REPLY_TO=

# Magic link TTL (days)
LINK_TTL_DAYS=7

# Session JWT TTL after login (days)
SESSION_TTL_DAYS=7

# Comma-separated domains allowed for new user invites
ALLOWED_EMAIL_DOMAINS=retailodyssey.com

# GitHub Pages frontend URL (no trailing slash)
FRONTEND_BASE_URL=https://d6ewasupervisor-netizen.github.io/district1

# Railway backend public URL
# BACKEND_BASE_URL=https://district1-production.up.railway.app

# Optional extra CORS origins (CSV, exact match)
# EXTRA_ALLOWED_ORIGINS=

# SAS session push from morning-auth.js
SAS_SESSION_PUSH_SECRET=replace-with-long-random-secret

# PROD sync interval (minutes)
SYNC_INTERVAL_MINUTES=15

PORT=3000
